<templates>
  <t t-name="o-spreadsheet-FunctionDescriptionProvider">
    <div class="o-formula-assistant-container user-select-none shadow">
      <t t-set="context" t-value="getContext()"/>
      <div class="o-formula-assistant" t-if="context.functionDescription.name">
        <div class="o-formula-assistant-head d-flex flex-row justify-content-between">
          <div
            style="display: flex; flex-direction: row; flex-wrap: wrap; align-items: center; word-break: break-word;">
            <t t-set="orderStyle" t-value="'order: 0;'"/>
            <t t-set="firstRepeatableGroupNotOptional" t-value="false"/>
            <t t-set="startRepeatableGroups" t-value="false"/>

            <span t-att-style="orderStyle">
              <span t-esc="context.functionDescription.name"/>
              (
            </span>

            <t t-foreach="context.functionDescription.args" t-as="arg" t-key="arg.name">
              <t t-set="prevArg" t-value="context.functionDescription.args[arg_index - 1]"/>
              <t t-set="nextArg" t-value="context.functionDescription.args[arg_index + 1]"/>
              <t t-if="arg.repeating">
                <t t-set="startRepeatableGroups" t-value="true"/>
                <t t-set="firstRepeatableGroupNotOptional" t-value="!arg.optional"/>
              </t>
              <t t-if="startRepeatableGroups and !arg.repeating">
                <t t-set="orderStyle" t-value="'order: 2;'"/>
              </t>

              <span t-att-style="orderStyle">
                <span>
                  <t
                    t-set="displayBrackets"
                    t-value="arg.optional || arg.default || (arg.repeating and (!firstRepeatableGroupNotOptional or context.repeatingArgGroupIndex > 0))"
                  />

                  <span t-if="arg_index > '0'" t-esc="formulaArgSeparator"/>

                  <t
                    t-if="arg.repeating and context.repeatingArgGroupIndex > 0 and (!prevArg or !prevArg.repeating)">
                    <span>...</span>
                    <span t-esc="formulaArgSeparator"/>
                  </t>

                  <span t-if="displayBrackets and (!prevArg or !prevArg.repeating)">[</span>
                  <span
                    t-att-class="{ 'o-formula-assistant-focus': context.argsToFocus.includes(arg_index) }">
                    <span t-if="arg.repeating">
                      <span t-esc="arg.name + (context.repeatingArgGroupIndex + 1)"/>
                    </span>
                    <span t-if="!arg.repeating">
                      <span t-esc="arg.name"/>
                    </span>
                  </span>
                  <span t-if="displayBrackets and (!nextArg or !nextArg.repeating)">]</span>
                </span>
              </span>

              <span t-if="arg.repeating" style="order: 1;">
                <span
                  t-if="arg_index > '0' or firstRepeatableGroupNotOptional"
                  t-esc="formulaArgSeparator"
                />
                <t t-if="!prevArg or !prevArg.repeating">
                  <span>[</span>
                </t>
                <span>
                  <span t-esc="arg.name + (context.repeatingArgGroupIndex + 2)"/>
                </span>
                <t t-if="!nextArg or !nextArg.repeating">
                  <span>]</span>
                  <span t-esc="formulaArgSeparator"/>
                  <span>...</span>
                </t>
              </span>
            </t>

            <span style="order: 3;">&#xA0;)</span>
          </div>
          <div
            class="collapsor px-2 d-flex align-items-center rounded"
            t-att-class="state.isCollapsed ? 'collapsed' : ''"
            t-on-click="() => this.toggle()">
            <span class="collapsor-arrow d-inline-block">
              <t t-call="o-spreadsheet-Icon.ANGLE_DOWN"/>
            </span>
          </div>
        </div>

        <Collapse isCollapsed="state.isCollapsed">
          <div class="o-formula-assistant-core pb-3 m-3">
            <div class="o-formula-assistant-gray">ABOUT</div>
            <div t-esc="context.functionDescription.description"/>
          </div>

          <t t-foreach="context.functionDescription.args" t-as="arg" t-key="arg.name">
            <div
              class="o-formula-assistant-arg p-3 pt-0 display-flex flex-column"
              t-att-class="{
                  'o-formula-assistant-gray': context.argsToFocus.length > 0,
                  'o-formula-assistant-focus': context.argsToFocus.includes(arg_index),
                }">
              <div>
                <span t-if="arg.repeating">
                  <span t-esc="arg.name + (context.repeatingArgGroupIndex + 1)"/>
                </span>
                <span t-if="!arg.repeating">
                  <span t-esc="arg.name"/>
                </span>
                <span
                  t-if="arg.optional || arg.default || (arg.repeating and (!firstRepeatableGroupNotOptional or context.repeatingArgGroupIndex > 0))">&#xA0;- [optional]&#xA0;</span>
                <span t-if="arg.default">
                  <span>default:&#xA0;</span>
                  <t t-esc="arg.defaultValue"/>
                </span>
              </div>
              <div class="o-formula-assistant-arg-description" t-esc="arg.description"/>
            </div>
          </t>
        </Collapse>
      </div>
    </div>
  </t>
</templates>
