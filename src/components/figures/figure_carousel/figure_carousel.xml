<templates>
  <t t-name="o-spreadsheet-CarouselFigure">
    <div class="o-carousel w-100 h-100 d-flex flex-column" t-on-dblclick="onCarouselDoubleClick">
      <t t-set="selectedItem" t-value="selectedCarouselItem"/>

      <!-- ROW LAYOUT: all items side by side, no tabs -->
      <t t-if="isRowLayout">
        <div
          t-if="title"
          class="o-carousel-header d-flex align-items-baseline flex-shrink-0 pe-1 pe-auto"
          t-att-style="headerStyle">
          <div
            class="o-carousel-title text-truncate flex-shrink-0 pe-2"
            t-out="title"
            t-att-title="title"
            t-att-style="titleStyle"
          />
          <div class="flex-fill"/>
          <div
            t-if="!env.isDashboard()"
            class="o-carousel-menu-button o-carousel-button fa fa-ellipsis-v rounded ms-1"
            t-on-click="openContextMenu"
          />
        </div>
        <div class="o-carousel-row-content d-flex flex-fill w-100">
          <t t-foreach="carousel.items" t-as="item" t-key="item_index">
            <div
              class="o-carousel-row-item"
              t-att-class="{'o-dashboard-row-item': env.isDashboard()}"
              t-att-style="getRowItemStyle(item_index)">
              <t t-if="item.type === 'chart'">
                <div class="o-chart-container w-100 h-100">
                  <t
                    t-component="getRowItemChartComponent(item)"
                    chartId="item.id"
                    t-key="item.id"
                  />
                </div>
              </t>
            </div>
          </t>
        </div>
      </t>

      <!-- GRID LAYOUT: items in a configurable grid -->
      <t t-elif="isGridLayout">
        <div
          t-if="title"
          class="o-carousel-header d-flex align-items-baseline flex-shrink-0 pe-1 pe-auto"
          t-att-style="headerStyle">
          <div
            class="o-carousel-title text-truncate flex-shrink-0 pe-2"
            t-out="title"
            t-att-title="title"
            t-att-style="titleStyle"
          />
          <div class="flex-fill"/>
          <div
            t-if="!env.isDashboard()"
            class="o-carousel-menu-button o-carousel-button fa fa-ellipsis-v rounded ms-1"
            t-on-click="openContextMenu"
          />
        </div>
        <div class="o-carousel-grid-content flex-fill w-100" t-att-style="getGridContainerStyle()">
          <t t-foreach="carousel.items" t-as="item" t-key="item_index">
            <div
              class="o-carousel-grid-item"
              t-att-class="{'o-dashboard-grid-item': env.isDashboard()}"
              t-att-style="getGridItemStyle(item)">
              <t t-if="item.type === 'chart'">
                <div class="o-chart-container w-100 h-100">
                  <t
                    t-component="getRowItemChartComponent(item)"
                    chartId="item.id"
                    t-key="item.id"
                  />
                </div>
              </t>
            </div>
          </t>
        </div>
      </t>

      <!-- TABS LAYOUT (default): one item at a time with tab selector -->
      <t t-else="">
        <div
          class="o-carousel-header d-flex align-items-baseline flex-shrink-0 pe-1 pe-auto"
          t-att-class="{
            'border-bottom': env.isDashboard(),
            'o-carousel-header-floating': !env.isDashboard() and isDataViewActive,
           }"
          t-att-style="headerStyle">
          <div
            class="o-carousel-title text-truncate flex-shrink-0 pe-2"
            t-out="title"
            t-att-title="title"
            t-att-style="titleStyle"
          />
          <div class="o-carousel-tabs d-flex flex-fill justify-content-end" t-ref="carouselTabs">
            <t t-foreach="visibleCarouselItems" t-as="item" t-key="item_index">
              <div
                class="o-carousel-tab text-truncate px-2 mt-1 flex-shrink-0"
                t-att-class="{ 'selected': isItemSelected(item) }"
                t-att-data-type="item.type"
                t-out="getItemTitle(item)"
                t-on-click.stop="() => this.onCarouselTabClick(item)"
              />
            </t>
            <div
              t-if="showDataViewTab"
              class="o-carousel-tab text-truncate px-2 mt-1 flex-shrink-0"
              t-att-class="{ 'selected': isDataViewActive }"
              data-type="dataView"
              t-on-click.stop="onDataViewTabClick">
              Data
            </div>
          </div>
          <div
            class="o-carousel-tabs-dropdown o-carousel-button flex-shrink-0 rounded p-1"
            t-att-class="{'active': menuState.isOpen}"
            t-ref="carouselTabsDropdown"
            t-on-click="toggleMenu">
            <div class="fa fa-angle-down"/>
            <MenuPopover
              t-if="menuState.isOpen"
              menuId="menuId"
              anchorRect="menuState.anchorRect"
              menuItems="menuState.menuItems"
              onClose="() => this.menuState.isOpen=false"
              popoverPositioning="'bottom-left'"
            />
          </div>
          <div
            t-if="env.isDashboard()"
            t-att-title="fullScreenButtonTitle"
            class="o-carousel-full-screen-button fa o-carousel-button rounded p-1 ms-1"
            t-att-class="{
              'fa-compress': props.isFullScreen,
              'fa-expand': !props.isFullScreen,
              'invisible': !selectedCarouselItem or (selectedCarouselItem?.type !== 'chart' and selectedCarouselItem?.type !== 'dataLayer'),
            }"
            t-on-click="toggleFullScreen"
          />
          <div
            t-if="!env.isDashboard()"
            class="o-carousel-menu-button o-carousel-button fa fa-ellipsis-v rounded ms-1"
            t-on-click="openContextMenu"
          />
        </div>
        <div
          t-if="!selectedItem"
          class="o-carousel-empty w-100 flex-fill d-flex align-items-center justify-content-center">
          <t t-call="o-spreadsheet-Icon.CAROUSEL"/>
        </div>
        <div
          t-elif="selectedItem.type === 'chart'"
          class="o-carousel-content w-100 flex-fill position-relative">
          <div class="o-chart-container w-100 h-100">
            <t
              t-component="chartComponent"
              chartId="selectedItem.id"
              isFullScreen="props.isFullScreen"
              t-key="selectedItem.id"
            />
          </div>
          <ChartDashboardMenu
            t-if="env.isDashboard()"
            chartId="selectedItem.id"
            hasFullScreenButton="false"
            t-key="selectedItem.id"
          />
        </div>
        <div
          t-elif="selectedItem.type === 'dataLayer'"
          class="o-carousel-content o-data-layer w-100 flex-fill position-relative">
          <canvas
            t-ref="dataLayerCanvas"
            class="w-100 h-100"
            t-on-click="onDataLayerClick"
            t-on-contextmenu.prevent="onDataLayerContextMenu"
            t-on-mousemove="onDataLayerMouseMove"
            t-on-mouseleave="onDataLayerMouseLeave"
          />
          <Popover
            t-if="filterPopover.isOpen"
            anchorRect="filterPopover.anchorRect"
            positioning="'bottom-left'"
            verticalOffset="0">
            <FilterMenu
              filterPosition="filterPopover.filterPosition"
              sheetId="filterPopover.sheetId"
              onClosed.bind="closeFilterPopover"
            />
          </Popover>
        </div>
      </t>
    </div>
  </t>
</templates>
