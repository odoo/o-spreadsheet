<templates>
  <t t-name="o-spreadsheet-FullScreenFigure">
    <div
      t-if="figureUI"
      class="o-fullscreen-figure o-figure position-absolute w-100 h-100"
      tabindex="1"
      t-ref="fullScreenFigure"
      t-on-keydown="(ev) => this.onKeyDown(ev)">
      <t
        t-component="figureRegistry.get(figureUI.tag).Component"
        t-key="figureUI"
        onFigureDeleted="() => {}"
        figureUI="figureUI"
      />
    </div>
  </t>
</templates>
