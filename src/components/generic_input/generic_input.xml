<templates>
  <div t-name="o-spreadsheet-GenericInput" class="w-100">
    <input
      t-ref="input"
      class="os-input w-100"
      t-att="props.attributes"
      t-att-class="inputClass"
      t-att-id="props.id"
      t-att-placeholder="props.placeholder"
      t-on-change="() => this.save(true)"
      t-on-blur="save"
      t-on-pointerdown="onMouseDown"
      t-on-pointerup="onMouseUp"
      t-on-keydown="onKeyDown"
    />
  </div>
</templates>
