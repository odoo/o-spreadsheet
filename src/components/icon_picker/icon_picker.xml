<templates>
  <t t-name="o-spreadsheet-IconPicker">
    <div class="o-icon-picker bg-white">
      <t t-foreach="['arrows', 'smiley', 'dots']" t-as="iconSet" t-key="iconSet">
        <div class="o-cf-icon-line">
          <div
            t-foreach="['good', 'neutral', 'bad']"
            t-as="iconType"
            t-key="iconType"
            class="o-icon-picker-item p-1"
            t-on-click="() => this.onIconClick(this.getIconName(iconSet, iconType))">
            <t t-call="{{this.getIconTemplate(this.getIconName(iconSet, iconType))}}"/>
          </div>
        </div>
      </t>
    </div>
  </t>
</templates>
