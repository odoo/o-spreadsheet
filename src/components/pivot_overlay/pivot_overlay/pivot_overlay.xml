<templates>
  <t t-name="o-spreadsheet-PivotOverlay">
    <div
      class="o-pivot-overlay position-absolute bg-white d-flex flex-column rounded shadow border overflow-auto"
      t-att-style="overlayStyle"
      t-ref="pivotOverlay"
      t-if="hasPivotFormula">
      <div
        class="o-pivot-overlay-top d-flex flex-row gap-2 border-bottom align-items-end top-0 start-0 position-sticky bg-white">
        <div
          class="o-pivot-measures o-pivot-overlay-section bg-white p-3 border-end d-flex flex-column gap-2">
          <t t-foreach="definition.measures" t-as="measure" t-key="measure_index">
            <PivotFacet
              icon="'measure'"
              label="measure.displayName"
              name="measure.id"
              onClickIcon="() => {}"
              onClickRemove="() => {}"
            />
          </t>
          <PivotFacet
            icon="'add'"
            label.translate="Add measure"
            name="'__measures_add__'"
            onClickIcon="() => {}"
          />
        </div>
        <div
          class="o-pivot-columns o-pivot-overlay-section bg-white p-3 d-flex flex-row align-items-center gap-2"
          t-on-dragover="(ev) => this.onDragOverColumn(ev)"
          t-on-drop="onDropColumn">
          <div class="o-pivot-overlay-title me-4">Columns</div>
          <div
            t-foreach="getDisplayedColumnsGroups()"
            t-as="column"
            t-key="column_index"
            class="d-flex flex-row align-items-center bg-white rounded"
            t-on-pointerdown="(ev) => this.startDragAndDrop(column, ev)"
            t-att-style="dragAndDrop.itemsStyle[column.nameWithGranularity]">
            <PivotFacet
              icon="'group'"
              label="column.displayName"
              name="column.nameWithGranularity"
              onClickIcon="() => {}"
              onClickRemove="() => this.onRemoveColumn(column)"
            />
            <span class="o-group-separator fw-bold ps-2 pb-2">&gt;</span>
          </div>
          <AddDimensionButton
            onFieldPicked.bind="onAddColumn"
            fields="this.pivotStore.unusedGroupableFields">
            <t t-set-slot="button">
              <PivotFacet
                icon="'add'"
                class="'o-add-group'"
                label.translate="Add group"
                onClickIcon="() => {}"
              />
            </t>
          </AddDimensionButton>
        </div>
      </div>
      <div class="d-flex flex-row">
        <div
          class="o-pivot-rows o-pivot-overlay-section bg-white p-3 d-flex flex-column align-items-center start-0 position-sticky bg-white">
          <span class="o-pivot-overlay-title mb-4">Rows</span>
          <div class="o-rotated d-flex flex-column align-items-center gap-2">
            <t t-foreach="definition.rows" t-as="row" t-key="row_index">
              <PivotFacet
                icon="'group'"
                label="row.displayName"
                name="row.nameWithGranularity"
                onClickIcon="() => {}"
                onClickRemove="() => {}"
                vertical="true"
              />
              <span class="o-group-separator fw-bold ps-2 pb-2">&gt;</span>
            </t>
            <PivotFacet
              icon="'add'"
              label.translate="Add group"
              name="'__rows_add__'"
              onClickIcon="() => {}"
              vertical="true"
            />
          </div>
        </div>
        <div class="p-3 border-start">
          <StandaloneGridCanvas t-props="pivotGridProps"/>
        </div>
      </div>
    </div>
  </t>
</templates>
