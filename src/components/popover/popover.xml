<templates>
  <t t-name="o-spreadsheet-Popover">
    <t t-custom-portal="'.o-spreadsheet'">
      <div
        class="o-popover rounded"
        t-att-class="this.props.class"
        t-custom-ref="popover"
        t-on-wheel="this.props.onMouseWheel"
        t-on-click.stop="">
        <div class="o-popover-content" t-custom-ref="popoverContent">
          <t t-call-slot="default"/>
        </div>
      </div>
    </t>
  </t>
</templates>
