<templates>
  <t t-name="o-spreadsheet-mobile-Selection">
    <div class="o-highlight" t-ref="highlight" t-on-scroll.stop.prevent="">
      <t t-foreach="directions" t-as="orientation" t-key="orientation">
        <Corner
          onResizeHighlight="(isLeft, isTop,target) => this.onResizeSelection(isLeft, isTop,target)"
          isResizing='selectionState.shiftingMode === "isResizing"'
          orientation="orientation"
          zone="env.model.getters.getSelectedZone()"
          color="COLOR"
        />
      </t>
    </div>
  </t>
</templates>
