<templates>
  <t t-name="o-spreadsheet-CarouselDataRangePanel">
    <Section>
      Data range
      <SelectionInput
        ranges="[this.carouselItem.range]"
        isInvalid="false"
        hasSingleRange="true"
        onSelectionChanged.bind="this.onRangeChange"
        onSelectionConfirmed.bind="this.onRangeConfirm"
        required="false"
      />
    </Section>
    <Section>
      <div class="o-section-title">Scale</div>
      <Select
        selectedValue="this.carouselItem.scale || 'actualSize'"
        values="scaleOptions"
        class="'o-scale'"
        onChange.bind="this.onScaleChange"
      />
    </Section>
    p
  </t>
</templates>
