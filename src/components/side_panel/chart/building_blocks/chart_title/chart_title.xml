<templates>
  <t t-name="o-spreadsheet.ChartTitle">
    <t t-set="title">
      <t t-if="props.name" t-esc="props.name"/>
      <t t-else="">Title</t>
    </t>
    <Section class="'o-chart-title'" title="title.toString()">
      <StandaloneComposer
        composerContent="props.title"
        onConfirm.bind="updateTitle"
        defaultRangeSheetId="env.model.getters.getActiveSheetId()"
        placeholder.translate="Enter text or formula"
      />
      <TextStyler
        style="props.style"
        updateStyle="props.updateStyle"
        defaultStyle="props.defaultStyle"
        hasHorizontalAlign="true"
      />
    </Section>
  </t>
</templates>
