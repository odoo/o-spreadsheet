<templates>
  <t t-name="o-spreadsheet-ChartShowValues">
    <Checkbox
      name="'showValues'"
      label.translate="Show values"
      value="this.props.definition.showValues ?? this.props.defaultValue"
      onChange="(showValues) => this.props.updateChart(this.props.chartId, { showValues })"
    />
  </t>
</templates>
