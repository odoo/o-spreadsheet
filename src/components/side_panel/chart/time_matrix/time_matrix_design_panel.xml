<templates>
  <t t-name="o-spreadsheet-TimeMatrixChartDesignPanel">
    <GeneralDesignEditor t-props="props">
      <t t-set-slot="general-extension">
        <Section class="'pt-0'" title.translate="Colormap">
          <div style="width: 100%">
            <div class="colormap-container" t-on-click="onPointerDown">
              <span class="colormap-label">
                <t t-esc="currentColormapLabel"/>
              </span>
              <div class="colormap-preview" t-att-class="currentColormapPreview"/>
              <span class="ms-1">
                <t t-call="o-spreadsheet-Icon.CARET_DOWN"/>
              </span>
            </div>
          </div>
          <Popover t-if="state.popoverProps" t-props="state.popoverProps">
            <div t-ref="popoverRef" class="o-chart-select-popover" t-att-style="state.popoverStyle">
              <div class="w-100">
                <t t-foreach="colormaps" t-as="colormap" t-key="colormap.value">
                  <div
                    class="colormap-container"
                    t-on-click="() => this.onColormapChange(colormap.value)">
                    <span class="colormap-label">
                      <t t-esc="colormap.label"/>
                    </span>
                    <div class="colormap-preview" t-att-class="colormap.className"/>
                  </div>
                </t>
              </div>
            </div>
          </Popover>
        </Section>
        <Section class="'pt-0'" title.translate="Values">
          <ChartShowValues t-props="props"/>
        </Section>
      </t>
    </GeneralDesignEditor>
    <SidePanelCollapsible isInitiallyCollapsed="true" title.translate="Axes">
      <t t-set-slot="content">
        <AxisDesignEditor
          axesList="axesList"
          figureId="props.figureId"
          definition="props.definition"
          updateChart="props.updateChart"
        />
      </t>
    </SidePanelCollapsible>
  </t>
</templates>
