<templates>
  <t t-name="o-spreadsheet-TreeMapChartDesignPanel">
    <GeneralDesignEditor
      figureId="props.figureId"
      definition="props.definition"
      updateChart="props.updateChart"
    />

    <SidePanelCollapsible collapsedAtInit="false" title.translate="Tree map colors">
      <t t-set-slot="content">
        <Section class="'pt-0'">
          <BadgeSelection
            choices="coloringOptionChoices"
            onChange.bind="changeColoringOption"
            selectedValue="coloringOptions.type"
          />

          <t
            t-if="coloringOptions.type === 'categoryColor'"
            t-call="o-spreadsheet-CategoryColorList"
          />
          <t t-else="" t-call="o-spreadsheet-SimpleColorScale"/>
        </Section>
      </t>
    </SidePanelCollapsible>

    <SidePanelCollapsible collapsedAtInit="false" title.translate="Headers and labels">
      <t t-set-slot="content">
        <Section title.translate="Headers" class="'pt-0 pb-0'">
          <Checkbox
            name="'showHeaders'"
            label.translate="Show headers"
            value="props.definition.showHeaders ?? defaults.showHeaders"
            onChange="(showHeaders) => props.updateChart(this.props.figureId, { showHeaders })"
          />
        </Section>
        <t t-if="showHeaders">
          <TextStyler
            class="'pt-0 o-header-style'"
            updateStyle="(headerDesign) => props.updateChart(this.props.figureId, { headerDesign })"
            style="props.definition.headerDesign || {}"
            defaultStyle="defaults.headerDesign"
            hasText="false"
            hasBackgroundColor="true"
          />
        </t>

        <Section title.translate="Labels" class="'pt-0 pb-0'">
          <div class="d-flex flex-row gap-4">
            <Checkbox
              name="'showLabels'"
              label.translate="Show labels"
              value="props.definition.showLabels ?? defaults.showLabels"
              onChange="(showLabels) => props.updateChart(this.props.figureId, { showLabels })"
            />
            <Checkbox
              name="'showValues'"
              label.translate="Show values"
              value="props.definition.showValues ?? defaults.showValues"
              onChange="(showValues) => props.updateChart(this.props.figureId, { showValues })"
            />
          </div>
        </Section>
        <t t-if="showValues || showLabels">
          <TextStyler
            class="'pt-0 o-values-style'"
            updateStyle="(valuesDesign) => props.updateChart(this.props.figureId, { valuesDesign })"
            style="props.definition.valuesDesign || {}"
            defaultStyle="defaults.valuesDesign"
            hasText="false"
            hasVerticalAlign="true"
          />
        </t>
      </t>
    </SidePanelCollapsible>
  </t>

  <t t-name="o-spreadsheet-CategoryColorList">
    <div class="mt-3">
      <div class="o-fw-bold mb-2">Category</div>
      <t t-foreach="getTreeGroupAndColors()" t-as="group" t-key="group.group">
        <div class="d-flex align-items-center mb-2" t-att-data-id="group.group">
          <RoundColorPicker
            currentColor="group.color"
            onColorPicked="(color) => this.setGroupColor(group.group, color)"
          />
          <span class="ps-2">
            <span class="" t-esc="group.group"/>
          </span>
        </div>
      </t>
      <Checkbox
        name="'highlightBigValues'"
        label.translate="Highlight bigger values"
        value="coloringOptions.highlightBigValues"
        onChange.bind="setHighlightBigValues"
        className="'mt-4'"
      />
    </div>
  </t>

  <t t-name="o-spreadsheet-SimpleColorScale">
    <div class="o-min-color d-flex align-items-center mb-2 mt-4">
      <RoundColorPicker
        currentColor="getColorScaleColor('minColor')"
        onColorPicked="(color) => this.setColorScaleColor('minColor', color)"
        disableNoColor="true"
      />
      <span class="ps-2">Color of minimum values</span>
    </div>
    <div class="o-mid-color d-flex align-items-center mb-2">
      <RoundColorPicker
        currentColor="getColorScaleColor('midColor')"
        onColorPicked="(color) => this.setColorScaleColor('midColor', color)"
      />
      <span class="ps-2">Color of middle values</span>
    </div>
    <div class="o-max-color d-flex align-items-center">
      <RoundColorPicker
        currentColor="getColorScaleColor('maxColor')"
        onColorPicked="(color) => this.setColorScaleColor('maxColor', color)"
        disableNoColor="true"
      />
      <span class="ps-2">Color of maximum values</span>
    </div>
  </t>
</templates>
