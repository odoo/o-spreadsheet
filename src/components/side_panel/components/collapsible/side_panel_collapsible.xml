<templates>
  <t t-name="o-spreadsheet-SidePanelCollapsible">
    <div class="o_side_panel_collapsible_title d-flex align-items-center p-2">
      <span
        t-att-id="'btn-collapse-'+props.name"
        t-att-class="{ 'collapsed': props.collapsedAtInit }"
        class="collapsor"
        data-bs-toggle="collapse"
        t-att-data-bs-target="'#box-collapse-'+props.name">
        <t t-slot="title"/>
      </span>
    </div>
    <div
      t-att-id="'box-collapse-'+props.name"
      t-att-class="{'show': !props.collapsedAtInit}"
      class="collapse">
      <t t-slot="content"/>
    </div>
  </t>
</templates>
