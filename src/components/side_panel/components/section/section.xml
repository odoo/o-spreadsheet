<templates>
  <t t-name="o_spreadsheet.Section">
    <div class="o-section" t-att-class="this.props.class">
      <t t-if="this.props.slots.title or this.props.title">
        <div class="o-section-title">
          <t t-out="this.props.title"/>
          <t t-call-slot="title"/>
        </div>
      </t>
      <t t-call-slot="default"/>
    </div>
  </t>
</templates>
