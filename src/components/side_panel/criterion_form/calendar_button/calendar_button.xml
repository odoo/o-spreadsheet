<templates>
  <t t-name="o-spreadsheet-CalendarButton">
    <div class="custom-date-container ms-1" style="position: relative; display: inline-block;">
      <button type="button" class="o-button btn" t-on-click="openCalendar">
        <i class="fa fa-calendar"/>
      </button>
      <input
        type="date"
        value="this.props.value"
        t-ref="hiddenDatePicker"
        style="position: absolute; opacity: 0; pointer-events: none; left: 0; top: 0; width: 0; height: 0;"
        t-att-id="this.props.id"
        t-on-change="(ev) => this.onDateInputValueChanged(ev.target.value)"
      />
    </div>
  </t>
</templates>
